# CryptoLiveDash Environment Variables
# Copy this file to .env.local and fill in values

# Binance API (defaults to public endpoints if not set)
VITE_BINANCE_REST_URL=https://api.binance.com
VITE_BINANCE_WS_URL=wss://stream.binance.com:9443/ws
VITE_BINANCE_STREAM_URL=wss://stream.binance.com:9443/stream
